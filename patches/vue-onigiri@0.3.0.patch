+const targets = /* @__PURE__ */ new Set();
+let invalidateManifest;
+export function registerOnigiriTarget(sourcePath) {
+  if (targets.has(sourcePath)) return;
+  targets.add(sourcePath);
+  invalidateManifest?.();
+}
+export function setOnigiriManifestInvalidator(fn) {
+  invalidateManifest = fn;
+}
+export function getOnigiriTargets() {
+  return Array.from(targets);
+}
+export function _resetOnigiriTargets() {
+  targets.clear();
+  invalidateManifest = void 0;
+}
